<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Warm wood-grain gradient: caramel → walnut, evokes a carrom board's playing surface. -->
    <path android:pathData="M0,0 L108,0 L108,108 L0,108 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="0" android:startY="0"
                android:endX="108" android:endY="108"
                android:startColor="#C8965C"
                android:endColor="#5C3317" />
        </aapt:attr>
    </path>

    <!-- Subtle warm radial highlight behind the book to lift it. -->
    <path android:pathData="M0,0 L108,0 L108,108 L0,108 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="54" android:centerY="54"
                android:gradientRadius="50"
                android:startColor="#44E5C18A"
                android:endColor="#00C8965C" />
        </aapt:attr>
    </path>
</vector>
