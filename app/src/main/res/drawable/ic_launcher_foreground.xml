<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!--
      Carrom Laws launcher icon.
      All artwork sits inside the adaptive-icon safe zone (33dp radius from centre 54,54).
      Composition: outer thin gold ring (board outer-circle abstraction), red Queen at centre
      with a subtle highlight, and four white pocket-dot accents at the safe-zone corners.
    -->

    <!-- Outer ring — gold, suggests the board's outer circle. -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFD54F"
        android:strokeAlpha="0.85"
        android:strokeWidth="1.6"
        android:pathData="M 54,54 m -28,0 a 28,28 0 1,0 56,0 a 28,28 0 1,0 -56,0" />

    <!-- Inner thin ring — soft white, depth. -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeAlpha="0.40"
        android:strokeWidth="0.8"
        android:pathData="M 54,54 m -22,0 a 22,22 0 1,0 44,0 a 22,22 0 1,0 -44,0" />

    <!-- Queen disc — red focal point with a subtle radial highlight. -->
    <path
        android:pathData="M 54,54 m -15,0 a 15,15 0 1,0 30,0 a 15,15 0 1,0 -30,0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="50" android:centerY="50"
                android:gradientRadius="18"
                android:startColor="#F55F5F"
                android:endColor="#B71C1C" />
        </aapt:attr>
    </path>

    <!-- Queen highlight — gives a tactile 3D feel. -->
    <path
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.35"
        android:pathData="M 50,50 m -4,0 a 4,4 0 1,0 8,0 a 4,4 0 1,0 -8,0" />

    <!-- Subtle red rim on the queen for definition. -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#7F0000"
        android:strokeAlpha="0.55"
        android:strokeWidth="0.8"
        android:pathData="M 54,54 m -15,0 a 15,15 0 1,0 30,0 a 15,15 0 1,0 -30,0" />

    <!-- Four pocket-dot accents inside the safe zone (distance 24 from centre). -->
    <path android:fillColor="#FFFFFF" android:fillAlpha="0.92"
        android:pathData="M 37,37 m -3,0 a 3,3 0 1,0 6,0 a 3,3 0 1,0 -6,0" />
    <path android:fillColor="#FFFFFF" android:fillAlpha="0.92"
        android:pathData="M 71,37 m -3,0 a 3,3 0 1,0 6,0 a 3,3 0 1,0 -6,0" />
    <path android:fillColor="#FFFFFF" android:fillAlpha="0.92"
        android:pathData="M 37,71 m -3,0 a 3,3 0 1,0 6,0 a 3,3 0 1,0 -6,0" />
    <path android:fillColor="#FFFFFF" android:fillAlpha="0.92"
        android:pathData="M 71,71 m -3,0 a 3,3 0 1,0 6,0 a 3,3 0 1,0 -6,0" />
</vector>
