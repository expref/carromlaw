<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!--
      Carrom Laws launcher icon — leather rulebook with a carrom emblem on the cover.
      Composition: rounded rectangular leather book (with a darker spine band on the left),
      a thin gold inner border, a circular gold-ringed carrom emblem with a red Queen disc,
      a two-line embossed title bar beneath the emblem, and four small gold corner-ticks
      that double as pocket markers and book corner brackets.
    -->

    <!-- Book body — leather, subtle linear gradient for tactile depth. -->
    <path android:pathData="M30,22 H78 A4,4 0 0 1 82,26 V82 A4,4 0 0 1 78,86 H30 A4,4 0 0 1 26,82 V26 A4,4 0 0 1 30,22 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="26" android:startY="22"
                android:endX="82" android:endY="86"
                android:startColor="#5A3823"
                android:endColor="#3A2014" />
        </aapt:attr>
    </path>

    <!-- Spine band — darker strip on the left of the book, sharing the rounded book corners. -->
    <path
        android:fillColor="#2D1810"
        android:pathData="M31,22 V86 H30 A4,4 0 0 1 26,82 V26 A4,4 0 0 1 30,22 Z" />

    <!-- Spine highlight — a thin warm line at the spine/cover seam. -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#6A4226"
        android:strokeAlpha="0.55"
        android:strokeWidth="0.4"
        android:pathData="M31,24 L31,84" />

    <!-- Inner cover border — thin gold rounded rectangle. -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#D4AF37"
        android:strokeAlpha="0.75"
        android:strokeWidth="0.6"
        android:pathData="M34,28 H74 A2,2 0 0 1 76,30 V78 A2,2 0 0 1 74,80 H34 A2,2 0 0 1 32,78 V30 A2,2 0 0 1 34,28 Z" />

    <!-- Carrom emblem — outer gold ring (board outer-circle abstraction). -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#D4AF37"
        android:strokeAlpha="0.9"
        android:strokeWidth="1.4"
        android:pathData="M54,48 m-12,0 a12,12 0 1,0 24,0 a12,12 0 1,0 -24,0" />

    <!-- Carrom emblem — soft inner ring for depth. -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeAlpha="0.35"
        android:strokeWidth="0.4"
        android:pathData="M54,48 m-10,0 a10,10 0 1,0 20,0 a10,10 0 1,0 -20,0" />

    <!-- Queen disc — radial gradient, off-centre highlight for tactile feel. -->
    <path
        android:pathData="M54,48 m-7,0 a7,7 0 1,0 14,0 a7,7 0 1,0 -14,0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="52" android:centerY="46"
                android:gradientRadius="9"
                android:startColor="#F55F5F"
                android:endColor="#B71C1C" />
        </aapt:attr>
    </path>

    <!-- Queen rim — dark red ring for definition. -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#5C0A0A"
        android:strokeAlpha="0.55"
        android:strokeWidth="0.4"
        android:pathData="M54,48 m-7,0 a7,7 0 1,0 14,0 a7,7 0 1,0 -14,0" />

    <!-- Queen highlight blob — small white spec for a 3D feel. -->
    <path
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.4"
        android:pathData="M52,46 m-1.8,0 a1.8,1.8 0 1,0 3.6,0 a1.8,1.8 0 1,0 -3.6,0" />

    <!-- Embossed title bar — two short gold lines under the emblem. -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#D4AF37"
        android:strokeAlpha="0.6"
        android:strokeWidth="0.6"
        android:pathData="M42,68 L66,68" />
    <path
        android:fillColor="#00000000"
        android:strokeColor="#D4AF37"
        android:strokeAlpha="0.55"
        android:strokeWidth="0.5"
        android:pathData="M42,72 L66,72" />

    <!-- Corner-tick markers — small gold dots that read as pocket markers / cover corners. -->
    <path android:fillColor="#D4AF37" android:fillAlpha="0.85"
        android:pathData="M35,31 m-0.9,0 a0.9,0.9 0 1,0 1.8,0 a0.9,0.9 0 1,0 -1.8,0" />
    <path android:fillColor="#D4AF37" android:fillAlpha="0.85"
        android:pathData="M73,31 m-0.9,0 a0.9,0.9 0 1,0 1.8,0 a0.9,0.9 0 1,0 -1.8,0" />
    <path android:fillColor="#D4AF37" android:fillAlpha="0.85"
        android:pathData="M35,77 m-0.9,0 a0.9,0.9 0 1,0 1.8,0 a0.9,0.9 0 1,0 -1.8,0" />
    <path android:fillColor="#D4AF37" android:fillAlpha="0.85"
        android:pathData="M73,77 m-0.9,0 a0.9,0.9 0 1,0 1.8,0 a0.9,0.9 0 1,0 -1.8,0" />
</vector>
